# ---------------------------------------------------------------------------
# flypewpet environment
#
# The app runs fully WITHOUT any of these set: it falls back to the bundled
# static seed data layer (src/lib/data/seed.ts). Set the Supabase vars to
# switch the data layer to a live Postgres/Supabase backend.
# ---------------------------------------------------------------------------

# Public Supabase project URL + anon key (used by the browser + server reads).
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Service-role key (server-only). Required for writing compatibility_checks
# and outbound_clicks from API routes when using Supabase.
SUPABASE_SERVICE_ROLE_KEY=

# Default affiliate network/tag appended to outbound carrier links when a
# carrier record does not carry its own affiliate URL. Optional.
NEXT_PUBLIC_AFFILIATE_TAG=flypewpet-20

# Base URL used when generating absolute share/links (optional).
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Protects the admin area (PATCH /api/admin/* and the /admin/* pages). When set,
# API requests must send a matching `x-admin-token` header and the /admin pages
# require HTTP Basic auth with this value as the password. Leave blank only for
# local dev (NODE_ENV!=production), where the admin area is unguarded. In any
# production build the admin area FAILS CLOSED until this is set — REQUIRED for
# Vercel/production deploys.
ADMIN_TOKEN=
